# =============================================================================
# 网络问题解决方案 - 环境变量配置
# =============================================================================

# 当前诊断结果：Google OAuth 服务连接被阻止
# 问题：网络环境无法访问 accounts.google.com
# 解决方案：使用以下配置之一

# -----------------------------------------------------------------------------
# 方案 1: 禁用 Google OAuth，只使用 GitHub（推荐用于开发）
# -----------------------------------------------------------------------------
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_AUTH_GITHUB_ENABLED=true

# 如果没有 GitHub OAuth 配置，请到以下地址创建：
# https://github.com/settings/developers
# 回调 URL: http://localhost:3000/api/auth/callback/github

# -----------------------------------------------------------------------------
# 方案 2: 网络代理配置（如果有可用代理）
# -----------------------------------------------------------------------------
# HTTP_PROXY=http://proxy-server:port
# HTTPS_PROXY=http://proxy-server:port
# NO_PROXY=localhost,127.0.0.1

# 继续启用 Google OAuth（如果代理可用）
# NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=true
# AUTH_GOOGLE_ID=your-google-client-id
# AUTH_GOOGLE_SECRET=your-google-client-secret
# NEXT_PUBLIC_AUTH_GOOGLE_ID=your-google-client-id

# -----------------------------------------------------------------------------
# 方案 3: 开发环境专用 - 模拟认证（仅用于测试）
# -----------------------------------------------------------------------------
# 启用一个简单的开发者认证模式
# DEV_AUTH_ENABLED=true
# DEV_AUTH_USER_EMAIL=developer@example.com
# DEV_AUTH_USER_NAME=Developer

# -----------------------------------------------------------------------------
# 网络诊断配置
# -----------------------------------------------------------------------------
# 启用网络诊断日志
DEBUG_NETWORK=true

# NextAuth 调试模式
NEXTAUTH_DEBUG=true

# 增加超时时间
NEXTAUTH_TIMEOUT=30000

# -----------------------------------------------------------------------------
# 部署环境建议
# -----------------------------------------------------------------------------
# 生产环境：部署到可以访问 Google 服务的服务器
# 推荐平台：
# - Vercel（全球 CDN）
# - Netlify（全球 CDN）  
# - Railway（海外服务器）
# - AWS/GCP/Azure（选择海外区域）

# 本地开发：建议使用 GitHub OAuth 作为主要认证方式
# 或使用代理/VPN 访问 Google 服务