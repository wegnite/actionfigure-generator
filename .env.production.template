# =============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION TEMPLATE
# Action Figure AI Generator - Production Deployment
# =============================================================================

# -----------------------------------------------------------------------------
# Web Information (PRODUCTION)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WEB_URL="https://yourdomain.com"
NEXT_PUBLIC_PROJECT_NAME="Action Figure AI Generator"

# -----------------------------------------------------------------------------
# Database with Supabase (PRODUCTION)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/postgres?sslmode=require"

# -----------------------------------------------------------------------------
# Auth with next-auth (PRODUCTION)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="[GENERATE_NEW_SECRET_FOR_PRODUCTION]"
AUTH_URL="https://yourdomain.com/api/auth"
AUTH_TRUST_HOST=true

# Google Auth (PRODUCTION)
AUTH_GOOGLE_ID="[PRODUCTION_GOOGLE_CLIENT_ID]"
AUTH_GOOGLE_SECRET="[PRODUCTION_GOOGLE_CLIENT_SECRET]"
NEXT_PUBLIC_AUTH_GOOGLE_ID="[PRODUCTION_GOOGLE_CLIENT_ID]"
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED="true"
NEXT_PUBLIC_AUTH_GOOGLE_ONE_TAP_ENABLED="true"

# Github Auth (PRODUCTION)
AUTH_GITHUB_ID="[PRODUCTION_GITHUB_CLIENT_ID]"
AUTH_GITHUB_SECRET="[PRODUCTION_GITHUB_CLIENT_SECRET]"
NEXT_PUBLIC_AUTH_GITHUB_ENABLED="true"

# -----------------------------------------------------------------------------
# Analytics (PRODUCTION)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID="[PRODUCTION_GA_ID]"
NEXT_PUBLIC_OPENPANEL_CLIENT_ID="[PRODUCTION_OPENPANEL_ID]"
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="yourdomain.com"
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL="https://plausible.io/js/script.js"

# -----------------------------------------------------------------------------
# Payment Configuration (PRODUCTION)
# -----------------------------------------------------------------------------
# Payment provider: 'stripe' or 'creem' or 'both'
PAY_PROVIDER="creem"

# Stripe (PRODUCTION)
STRIPE_PUBLIC_KEY="pk_live_[PRODUCTION_STRIPE_PUBLIC_KEY]"
STRIPE_PRIVATE_KEY="sk_live_[PRODUCTION_STRIPE_SECRET_KEY]"
STRIPE_WEBHOOK_SECRET="whsec_[PRODUCTION_STRIPE_WEBHOOK_SECRET]"

# Creem (PRODUCTION) - CRITICAL SECURITY SETTINGS
CREEM_API_KEY="[PRODUCTION_CREEM_API_KEY]"
CREEM_ENV="prod"
CREEM_WEBHOOK_SECRET="[PRODUCTION_CREEM_WEBHOOK_SECRET]"

# Creem Product Mapping (PRODUCTION)
# Map your product_id to actual Creem product IDs
CREEM_PRODUCTS="{\"creator\":\"prod_[ACTUAL_CREEM_PRODUCT_ID_1]\",\"professional\":\"prod_[ACTUAL_CREEM_PRODUCT_ID_2]\",\"enterprise\":\"prod_[ACTUAL_CREEM_PRODUCT_ID_3]\"}"

# Payment URLs (PRODUCTION)
NEXT_PUBLIC_PAY_SUCCESS_URL="https://yourdomain.com/pay-success"
NEXT_PUBLIC_PAY_FAIL_URL="https://yourdomain.com/pricing"
NEXT_PUBLIC_PAY_CANCEL_URL="https://yourdomain.com/pricing"

# -----------------------------------------------------------------------------
# Storage with AWS S3 (PRODUCTION)
# -----------------------------------------------------------------------------
STORAGE_ENDPOINT="[PRODUCTION_S3_ENDPOINT]"
STORAGE_REGION="[PRODUCTION_S3_REGION]"
STORAGE_ACCESS_KEY="[PRODUCTION_S3_ACCESS_KEY]"
STORAGE_SECRET_KEY="[PRODUCTION_S3_SECRET_KEY]"
STORAGE_BUCKET="[PRODUCTION_S3_BUCKET]"
STORAGE_DOMAIN="[PRODUCTION_S3_DOMAIN]"

# -----------------------------------------------------------------------------
# AI Services (PRODUCTION)
# -----------------------------------------------------------------------------
OPENAI_API_KEY="[PRODUCTION_OPENAI_KEY]"
DEEPSEEK_API_KEY="[PRODUCTION_DEEPSEEK_KEY]"
KLING_API_KEY="[PRODUCTION_KLING_KEY]"
REPLICATE_API_TOKEN="[PRODUCTION_REPLICATE_TOKEN]"
OPENROUTER_API_KEY="[PRODUCTION_OPENROUTER_KEY]"

# -----------------------------------------------------------------------------
# Security and Admin Settings (PRODUCTION)
# -----------------------------------------------------------------------------
ADMIN_EMAILS="admin@yourdomain.com,support@yourdomain.com"
NEXT_PUBLIC_LOCALE_DETECTION="true"
NEXT_PUBLIC_DEFAULT_THEME="light"

# Google Adsense (PRODUCTION)
NEXT_PUBLIC_GOOGLE_ADCODE="[PRODUCTION_ADSENSE_CODE]"

# -----------------------------------------------------------------------------
# Monitoring and Logging (PRODUCTION)
# -----------------------------------------------------------------------------
# Sentry for error tracking
NEXT_PUBLIC_SENTRY_DSN="[PRODUCTION_SENTRY_DSN]"
SENTRY_AUTH_TOKEN="[PRODUCTION_SENTRY_AUTH_TOKEN]"

# LogRocket for session recording
NEXT_PUBLIC_LOGROCKET_APP_ID="[PRODUCTION_LOGROCKET_ID]"

# DataDog for monitoring
DD_API_KEY="[PRODUCTION_DATADOG_API_KEY]"
DD_APP_KEY="[PRODUCTION_DATADOG_APP_KEY]"

# -----------------------------------------------------------------------------
# Performance and Caching (PRODUCTION)
# -----------------------------------------------------------------------------
REDIS_URL="redis://[PRODUCTION_REDIS_HOST]:[PORT]"
REDIS_PASSWORD="[PRODUCTION_REDIS_PASSWORD]"

# CDN Configuration
NEXT_PUBLIC_CDN_URL="https://cdn.yourdomain.com"

# -----------------------------------------------------------------------------
# Webhook Security (PRODUCTION)
# -----------------------------------------------------------------------------
# Rate limiting for webhooks (requests per minute)
WEBHOOK_RATE_LIMIT=60

# IP whitelist for Creem webhooks (comma-separated)
CREEM_WEBHOOK_IPS="52.89.214.238,34.212.75.30,54.218.53.128"

# -----------------------------------------------------------------------------
# Environment Identification
# -----------------------------------------------------------------------------
NODE_ENV="production"
VERCEL_ENV="production"
NEXT_PUBLIC_ENVIRONMENT="production"

# -----------------------------------------------------------------------------
# Security Headers and CSP
# -----------------------------------------------------------------------------
# Content Security Policy
NEXT_PUBLIC_CSP_REPORT_URI="https://yourdomain.com/api/csp-report"

# CORS Origins (comma-separated)
CORS_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"

# -----------------------------------------------------------------------------
# Database Connection Pool (PRODUCTION)
# -----------------------------------------------------------------------------
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=60000

# -----------------------------------------------------------------------------
# Rate Limiting (PRODUCTION)
# -----------------------------------------------------------------------------
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# -----------------------------------------------------------------------------
# Backup and Recovery (PRODUCTION)
# -----------------------------------------------------------------------------
BACKUP_STORAGE_BUCKET="[PRODUCTION_BACKUP_BUCKET]"
BACKUP_ENCRYPTION_KEY="[PRODUCTION_BACKUP_ENCRYPTION_KEY]"

# =============================================================================
# SECURITY CHECKLIST:
# =============================================================================
# [ ] All secrets generated fresh for production
# [ ] Webhook secrets are cryptographically secure
# [ ] Database uses SSL connections
# [ ] Rate limiting configured appropriately
# [ ] Monitoring and alerting configured
# [ ] Backup strategies implemented
# [ ] IP whitelisting configured for webhooks
# [ ] CSP and security headers configured
# [ ] Error tracking with Sentry configured
# [ ] Performance monitoring configured
# =============================================================================